generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// ENUMS
// ==========================================

enum ConnectionMode {
  QR
  MANAGED
  OWN_ACCOUNT
}

enum ConnectionStatus {
  CONNECTED
  DISCONNECTED
  PENDING
  EXPIRED
  REQUIRES_RECONNECTION
  TOKEN_EXPIRED
  ERROR
}

enum InfoMode {
  SIMPLE
  ADVANCED
}

enum MessageDirection {
  INCOMING
  OUTGOING
}

enum DataSourceType {
  DATABASE
  API
  ENDPOINT
}

enum IntegrationType {
  CALENDAR
  CRM
  PAYMENTS
  STORAGE
  KNOWLEDGE
  ECOMMERCE
  TICKETS
  NOTIFICATIONS
  AUTOMATION
}

enum IntegrationProvider {
  GOOGLE_CALENDAR
  GOOGLE_SHEETS
  GOOGLE_DRIVE
  NOTION
  HUBSPOT
  SLACK
  SHOPIFY
  WOOCOMMERCE
  ZENDESK
  ZAPIER
  MAKE
}

// ==========================================
// MODELS
// ==========================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  company   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  connections   WhatsAppConnection[]
  assistants    AssistantConfig[]
  infoFields    InfoField[]
  conversations Conversation[]
  dataSources   DataSource[]
  integrations  Integration[]

  @@map("users")
}

model WhatsAppConnection {
  id              String           @id @default(cuid())
  userId          String
  phoneNumber     String?
  displayName     String?
  mode            ConnectionMode   @default(QR)
  status          ConnectionStatus @default(PENDING)
  sessionData     Json?
  lastActive      DateTime?
  
  // Asistente IA Específico por Conexión
  assistantConfigId String?
  isAssistantActive Boolean          @default(true)

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // Cloud API fields
  wabaId          String?          // WhatsApp Business Account ID
  waPhoneNumberId String?          // Cloud API phone number ID
  accessToken     String?   @db.Text // Long-lived token (OWN_ACCOUNT)
  tokenExpiresAt  DateTime?        // When the access token expires
  webhookSecret   String?          // Per-connection webhook verification

  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages        Message[]
  assistantConfig AssistantConfig?   @relation(fields: [assistantConfigId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([phoneNumber])
  @@map("whatsapp_connections")
}

model AssistantConfig {
  id             String   @id @default(cuid())
  userId         String
  name           String   @default("Perfil Principal")
  behaviorPrompt String   @db.Text
  infoMode       InfoMode @default(SIMPLE)
  simpleInfo     String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  connections WhatsAppConnection[]

  @@index([userId])
  @@map("assistant_configs")
}

model InfoField {
  id      String @id @default(cuid())
  userId  String
  label   String
  content String @db.Text
  order   Int    @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("info_fields")
}

model Conversation {
  id          String   @id @default(cuid())
  userId      String
  clientPhone String
  clientName  String?
  isArchived  Boolean  @default(false)
  metadata    Json?    // Estado de conversación multi-turn (antes en Redis)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([userId, clientPhone])
  @@index([userId])
  @@map("conversations")
}

model Message {
  id             String           @id @default(cuid())
  conversationId String
  connectionId   String
  direction      MessageDirection
  content        String           @db.Text
  mediaUrl       String?
  externalId     String?          // ID original del mensaje (WhatsApp msg ID)
  timestamp      DateTime         @default(now())

  conversation Conversation       @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  connection   WhatsAppConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([connectionId])
  @@index([timestamp])
  @@index([externalId])
  @@map("messages")
}

model DataSource {
  id       String         @id @default(cuid())
  userId   String
  name     String
  type     DataSourceType
  config   Json
  isActive Boolean        @default(true)
  lastTest DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("data_sources")
}

model QueueJob {
  id           String    @id @default(cuid())
  queue        String    // "incoming" | "ai_processing" | "outgoing"
  connectionId String
  payload      Json
  status       String    @default("pending") // pending | processing | completed | failed
  attempts     Int       @default(0)
  maxAttempts  Int       @default(3)
  error        String?   @db.Text
  lastError    String?   @db.Text
  nextRetryAt  DateTime  @default(now())
  createdAt    DateTime  @default(now())
  completedAt  DateTime?

  @@index([queue, status])
  @@index([queue, status, nextRetryAt])
  @@index([connectionId])
  @@map("queue_jobs")
}

// ==========================================
// INTEGRATIONS (MCP)
// ==========================================

model Integration {
  id            String              @id @default(cuid())
  userId        String
  type          IntegrationType
  provider      IntegrationProvider
  isActive      Boolean             @default(true)
  enabledTools  Json?               // ["check_availability", "create_event", ...]
  allowedScopes Json?               // ["calendar.read", "calendar.write", ...]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  user     User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  accounts IntegrationAccount[]
  toolLogs ToolExecution[]

  @@unique([userId, provider])
  @@index([userId])
  @@map("integrations")
}

model IntegrationAccount {
  id            String      @id @default(cuid())
  integrationId String
  label         String      // "Calendar Empresa", "Calendar Personal"
  credentials   Json        // { accessToken, refreshToken, ... }
  config        Json?       // { calendarId, ... }
  isDefault     Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  integration Integration   @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  toolLogs    ToolExecution[]

  @@index([integrationId])
  @@map("integration_accounts")
}

model ToolExecution {
  id              String    @id @default(cuid())
  integrationId   String
  accountId       String?
  conversationId  String?
  toolName        String
  input           Json
  output          Json?
  status          String    @default("pending") // pending | running | completed | failed | timeout
  attempt         Int       @default(1)
  durationMs      Int?
  error           String?   @db.Text
  createdAt       DateTime  @default(now())

  integration Integration        @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  account     IntegrationAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([integrationId])
  @@index([conversationId])
  @@index([createdAt])
  @@map("tool_executions")
}

// ==========================================
// AGENT MEMORY & OBSERVABILITY
// ==========================================

model AgentMemory {
  id        String   @id @default(cuid())
  userId    String
  phone     String?  // null = global, set = per-client
  key       String
  value     String   @db.Text
  category  String   @default("general") // preference | fact | instruction
  score     Float    @default(1.0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, phone, key])
  @@index([userId, phone])
  @@index([userId, phone, score])
  @@map("agent_memories")
}

model AgentRun {
  id              String   @id @default(cuid())
  userId          String
  conversationId  String
  messageContent  String   @db.Text
  response        String   @db.Text
  iterations      Int
  totalTokens     Int
  totalDurationMs Int
  toolsUsed       Json?    // ["google_calendar__create_event"]
  steps           Json?    // Array of step objects
  status          String   @default("completed") // completed | error | timeout
  error           String?  @db.Text
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([conversationId])
  @@index([createdAt])
  @@map("agent_runs")
}
